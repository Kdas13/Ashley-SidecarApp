{
  "expo": {
    "name": "Atlas One",
    "slug": "atlas-one-apk",
    "version": "1.4.2",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.kdas13.atlasone",
      "versionCode": 16,
      "permissions": [
        "INTERNET"
      ],
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-document-picker",
      "expo-sharing"
    ]
  }
}
