{
  "name": "@echo/mobile",
  "version": "0.5.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "doctor": "npx expo-doctor",
    "config:public": "npx expo config --type public",
    "build:preview": "eas build --platform android --profile preview --non-interactive",
    "build:production": "eas build --platform android --profile production --non-interactive"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.5",
    "expo": "~57.0.6",
    "expo-constants": "~57.0.5",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "react-server-dom-webpack": "19.2.7"
  },
  "devDependencies": { "@types/react": "19.2.14", "typescript": "~6.0.3" },
  "expo": { "install": { "exclude": ["react", "react-dom", "react-server-dom-webpack"] } }
}
